@{
    ViewData["Title"] = "Reportes";
}

<div class="card shadow-sm mb-4">

    <div class="card-body">

        <div class="row">

            <div class="col-md-4">
                <label>Fecha Inicio</label>
                <input type="date" class="form-control">
            </div>

            <div class="col-md-4">
                <label>Fecha Fin</label>
                <input type="date" class="form-control">
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-primary w-100">
                    Generar Reporte
                </button>
            </div>

        </div>

    </div>

</div>

<div class="row g-3">

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6>Ventas Totales</h6>
                <h3>₡8.5M</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6>Productos Vendidos</h6>
                <h3>580</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6>Clientes Nuevos</h6>
                <h3>35</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6>Ganancia</h6>
                <h3>₡2.1M</h3>
            </div>
        </div>
    </div>

</div>

<div class="card mt-4 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-graph-up-arrow display-1 text-success"></i>
        <h4>Gráfico de Ventas</h4>
    </div>
</div>