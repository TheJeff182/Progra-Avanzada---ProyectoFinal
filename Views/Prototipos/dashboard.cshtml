@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6>Productos</h6>
                <h2 class="text-primary">520</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6>Clientes</h6>
                <h2 class="text-success">180</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6>Ventas</h6>
                <h2 class="text-info">140</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6>Ingresos</h6>
                <h2 class="text-warning">₡5.2M</h2>
            </div>
        </div>
    </div>

</div>

<div class="card shadow-sm">
    <div class="card-body">

        <h5>Ventas Mensuales</h5>

        <div class="text-center py-5">
            <i class="bi bi-bar-chart-line display-1 text-primary"></i>
            <p class="text-muted mt-3">
                Aquí se mostrará un gráfico de ventas.
            </p>
        </div>

    </div>
</div>