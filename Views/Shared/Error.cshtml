@model ProyectoFinal.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <p style="font-size:4rem;">⚠️</p>
    <h2 class="fw-semibold mb-2">Ocurrió un error</h2>
    <p class="text-muted mb-4">Algo salió mal al procesar tu solicitud.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted" style="font-size:0.8rem;">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm px-4">
        Volver al inicio
    </a>
</div>
