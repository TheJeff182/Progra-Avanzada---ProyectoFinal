<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PixelTico</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
</head>
<body>

    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
        var pageTitle = ViewData["Title"]?.ToString() ?? "PixelTico";
    }

    <!-- ── Sidebar ── -->
    <aside class="pt-sidebar">
        <div class="pt-sidebar-brand">
            <a asp-controller="Home" asp-action="Index">
                <span>🎮</span> PixelTico
            </a>
            <small>Gestor de tienda</small>
        </div>

        <nav class="pt-nav">
            <div class="pt-nav-label">General</div>
            <a class="pt-nav-link @(ctrl == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                Inicio
            </a>

            <div class="pt-nav-label">Catálogo</div>
            <a class="pt-nav-link @(ctrl == "Productos" ? "active" : "")"
               asp-controller="Productos" asp-action="Index">
                Productos
            </a>

        </a>
        <a class="pt-nav-link @(ctrl == "Clientes" ? "active" : "")"
           asp-controller="Clientes" asp-action="Index">
            Clientes
        </a>

        <div class="pt-nav-label">Ventas</div>
        <a class="pt-nav-link @(ctrl == "Ventas" ? "active" : "")"
           asp-controller="Ventas" asp-action="Index">
            Nueva Venta
        </a>
        <a class="pt-nav-link @(ctrl == "Pedidos" ? "active" : "")"
           asp-controller="Pedidos" asp-action="Index">
            Historial de Ventas
        </a>

        <div class="pt-nav-label">Prototipos</div>

        <a class="pt-nav-link @(ctrl == "Login" ? "active" : "")"
           asp-controller="Prototipos" asp-action="Login">
            Login
        </a>

        <a class="pt-nav-link @(ctrl == "Dashboard" ? "active" : "")"
           asp-controller="Prototipos" asp-action="Dashboard">
            Dashboard
        </a>

        <a class="pt-nav-link @(ctrl == "Reportes" ? "active" : "")"
           asp-controller="Prototipos" asp-action="Reportes">
            Reportes
        </a>

        <a class="pt-nav-link @(ctrl == "Usuarios" ? "active" : "")"
           asp-controller="Prototipos" asp-action="Usuarios">
            Usuarios
        </a>

    </nav>

    <div class="pt-sidebar-footer">
        PixelTico &copy; @DateTime.Now.Year
    </div>
</aside>

<!-- ── Topbar ── -->
<div class="pt-topbar">
    <span class="pt-topbar-title">@pageTitle</span>
    <div class="pt-topbar-right">
        <span>@DateTime.Now.ToString("dd/MM/yyyy")</span>
        <div class="pt-user-badge">
            <div class="pt-avatar">AD</div>
            Admin
        </div>
    </div>
</div>

<!-- ── Contenido ── -->
<main class="pt-main">
    <partial name="_Alerts" />
    @RenderBody()
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
