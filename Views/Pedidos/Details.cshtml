@model Pedido
@{
    ViewData["Title"] = "Factura #" + Model.Id;
}

<div class="row mb-4">
    <div class="col-md-8">
        <h4 class="fw-bold mb-0">Factura #@Model.Id</h4>
        <span class="text-muted">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver al historial
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="table-card p-3 h-100">
            <h6 class="fw-bold mb-3">Cliente</h6>
            <p class="mb-1"><strong>@Model.Cliente?.Nombre</strong></p>
            <p class="mb-1 text-muted">Cédula: @Model.Cliente?.Cedula</p>
            @if (!string.IsNullOrEmpty(Model.Cliente?.Correo))
            {
                <p class="mb-1 text-muted">Correo: @Model.Cliente.Correo</p>
            }
            @if (!string.IsNullOrEmpty(Model.Cliente?.Telefono))
            {
                <p class="mb-0 text-muted">Teléfono: @Model.Cliente.Telefono</p>
            }
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="table-card p-3 h-100">
            <h6 class="fw-bold mb-3">Venta</h6>
            <p class="mb-1">Atendido por: @Model.Usuario?.Nombre</p>
            <p class="mb-1">
                Estado:
                @if (Model.Estado == "Completado")
                {
                    <span class="badge bg-success">@Model.Estado</span>
                }
                else
                {
                    <span class="badge bg-secondary">@Model.Estado</span>
                }
            </p>
        </div>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Producto</th>
                    <th class="text-end">Precio unit.</th>
                    <th class="text-end">Cantidad</th>
                    <th class="text-end">Descuento</th>
                    <th class="text-end">Impuesto</th>
                    <th class="text-end">Total línea</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detalle in Model.PedidoDetalles)
                {
                    <tr>
                        <td>@detalle.Producto?.Nombre</td>
                        <td class="text-end">@detalle.PrecioUnit.ToString("C2")</td>
                        <td class="text-end">@detalle.Cantidad</td>
                        <td class="text-end">@(detalle.Descuento > 0 ? detalle.Descuento.ToString("C2") : "—")</td>
                        <td class="text-end">@detalle.ImpuestoPorc.ToString("F2")%</td>
                        <td class="text-end"><strong>@detalle.TotalLinea.ToString("C2")</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="p-3 border-top">
        <div class="row justify-content-end">
            <div class="col-md-4">
                <div class="d-flex justify-content-between">
                    <span>Subtotal:</span>
                    <span>@Model.Subtotal.ToString("C2")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Impuestos:</span>
                    <span>@Model.Impuestos.ToString("C2")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <h5 class="fw-bold mb-0">Total:</h5>
                    <h5 class="fw-bold mb-0">@Model.Total.ToString("C2")</h5>
                </div>
            </div>
        </div>
    </div>
</div>
