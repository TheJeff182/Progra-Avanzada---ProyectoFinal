@model List<Pedido>
@{
    ViewData["Title"] = "Historial de Ventas";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h4 class="fw-bold mb-0">Historial de Ventas</h4>
    </div>
    <div class="col-md-4 text-end">
        <a asp-controller="Ventas" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Venta
        </a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Todavía no hay ventas registradas. <a asp-controller="Ventas" asp-action="Index">Registrar la primera</a>
    </div>
}
else
{
    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Subtotal</th>
                        <th>Impuestos</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.Id</strong></td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Cliente?.Nombre</td>
                            <td>@item.Subtotal.ToString("C2")</td>
                            <td>@item.Impuestos.ToString("C2")</td>
                            <td><strong>@item.Total.ToString("C2")</strong></td>
                            <td>
                                @if (item.Estado == "Completado")
                                {
                                    <span class="badge bg-success">@item.Estado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Estado</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Ver factura">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if ((int?)ViewData["totalPages"] > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if ((int?)ViewData["currentPage"] > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="1">Primera</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@((int?)ViewData["currentPage"] - 1)">Anterior</a>
                    </li>
                }

                @for (int i = Math.Max(1, ((int?)ViewData["currentPage"] ?? 1) - 2); i <= Math.Min((int?)ViewData["totalPages"] ?? 1, ((int?)ViewData["currentPage"] ?? 1) + 2); i++)
                {
                    <li class="page-item @(i == (int?)ViewData["currentPage"] ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                @if ((int?)ViewData["currentPage"] < (int?)ViewData["totalPages"])
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@((int?)ViewData["currentPage"] + 1)">Siguiente</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@ViewData["totalPages"]">Última</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
