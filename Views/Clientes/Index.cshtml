@model List<Cliente>
@{
    ViewData["Title"] = "Gestion de Clientes";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h4 class="fw-bold mb-0">@ViewData["Title"]</h4>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Cliente
        </a>
    </div>
</div>

<div class="table-card p-3 mb-4">
    <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-10">
                <label for="buscar" class="form-label">Buscar Cliente</label>
                <input type="text" name="buscar" id="buscar" class="form-control" value="@ViewData["buscar"]" placeholder="Buscar por nombre o cedula...">
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-info w-100">Buscar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </form>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No hay clientes disponibles. <a asp-action="Create">Crear uno ahora</a>
    </div>
}
else
{
    <div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Nombre</th>
                    <th>Cedula</th>
                    <th>Correo</th>
                    <th>Telefono</th>
                    <th>Direccion</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Nombre</strong></td>
                        <td>@item.Cedula</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Correo))
                            {
                                <a href="mailto:@item.Correo">@item.Correo</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Telefono))
                            {
                                <a href="tel:@item.Telefono">@item.Telefono</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@(!string.IsNullOrEmpty(item.Direccion) ? item.Direccion : "-")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Ver">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    </div>

    @if ((int?)ViewData["totalPages"] > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if ((int?)ViewData["currentPage"] > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["buscar"]" asp-route-page="1">Primera</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["buscar"]" asp-route-page="@((int?)ViewData["currentPage"] - 1)">Anterior</a>
                    </li>
                }

                @for (int i = Math.Max(1, ((int?)ViewData["currentPage"] ?? 1) - 2); i <= Math.Min((int?)ViewData["totalPages"] ?? 1, ((int?)ViewData["currentPage"] ?? 1) + 2); i++)
                {
                    <li class="page-item @(i == (int?)ViewData["currentPage"] ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["buscar"]" asp-route-page="@i">@i</a>
                    </li>
                }

                @if ((int?)ViewData["currentPage"] < (int?)ViewData["totalPages"])
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["buscar"]" asp-route-page="@((int?)ViewData["currentPage"] + 1)">Siguiente</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["buscar"]" asp-route-page="@ViewData["totalPages"]">Última</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
