@model Cliente
@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1>@ViewData["Title"]</h1>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Cédula</dt>
            <dd class="col-sm-9">@Model.Cedula</dd>

            <dt class="col-sm-3">Correo</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.Correo))
                {
                    <a href="mailto:@Model.Correo">@Model.Correo</a>
                }
                else
                {
                    <span class="text-muted">No especificado</span>
                }
            </dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.Telefono))
                {
                    <a href="tel:@Model.Telefono">@Model.Telefono</a>
                }
                else
                {
                    <span class="text-muted">No especificado</span>
                }
            </dd>

            <dt class="col-sm-3">Dirección</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.Direccion))
                {
                    @Model.Direccion
                }
                else
                {
                    <span class="text-muted">No especificada</span>
                }
            </dd>
        </dl>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Eliminar</a>
        </div>
    </div>
</div>
