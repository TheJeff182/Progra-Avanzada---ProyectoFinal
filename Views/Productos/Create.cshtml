@model Producto
@{
    ViewData["Title"] = "Crear Producto";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1>@ViewData["Title"]</h1>
        <hr />

        <form asp-action="Create" method="post" class="needs-validation" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Laptop HP">
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label">Categoría <span class="text-danger">*</span></label>
                <select asp-for="CategoriaId" class="form-select">
                    <option value="">-- Seleccione una categoría --</option>
                    @foreach (var cat in (List<Categoria>)ViewData["categories"])
                    {
                        <option value="@cat.Id">@cat.Nombre</option>
                    }
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Precio" class="form-label"></label>
                        <input asp-for="Precio" class="form-control" placeholder="0.00" type="number" step="0.01">
                        <span asp-validation-for="Precio" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ImpuestoPorc" class="form-label"></label>
                        <input asp-for="ImpuestoPorc" class="form-control" placeholder="13.00" type="number" step="0.01">
                        <span asp-validation-for="ImpuestoPorc" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Stock" class="form-label"></label>
                <input asp-for="Stock" class="form-control" placeholder="0" type="number">
                <span asp-validation-for="Stock" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImagenUrl" class="form-label">URL de Imagen</label>
                <input asp-for="ImagenUrl" class="form-control" placeholder="https://ejemplo.com/imagen.jpg">
                <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" asp-for="Activo" class="form-check-input" checked>
                <label asp-for="Activo" class="form-check-label"></label>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
